# Service
APP_NAME=medical-ocr-api
ENV=development
LOG_LEVEL=INFO

# HTTP server
HTTP_HOST=0.0.0.0
HTTP_PORT=8989
MAX_UPLOAD_SIZE_BYTES=10485760
MAX_JSON_BODY_BYTES=262144

# Rate limiting (slowapi syntax: <count>/<period>)
RATE_LIMIT_DEFAULT=100/minute
RATE_LIMIT_UPLOAD=3/minute
RATE_LIMIT_WRITE=10/minute

# MQTT broker
MQTT_HOST=mosquitto
MQTT_PORT=8883
MQTT_TLS_CA=/certs/ca.crt
MQTT_TLS_CERT=/certs/api_server.crt
MQTT_TLS_KEY=/certs/api_server.key
MQTT_CLIENT_ID=api_server

# OCR queue (file-based for dev; replace with redis://... in prod)
OCR_QUEUE_DIR=/tmp/ocr-queue

# Confidence threshold (0.0 - 1.0). Don't lower without TARA review.
OCR_CONFIDENCE_THRESHOLD=0.95
